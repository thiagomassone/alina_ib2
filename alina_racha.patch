@@ -0,0 +1,140 @@
+"""Badge de racha de uso para el header del Resumen.
+
+Muestra una llama + el número de días de racha, en un pill al lado del saludo.
+Cuando la racha sube un día, reproduce una animación estilo Duolingo:
+la llama se prende (gris → ámbar), hace un bounce y salta confeti.
+
+Uso:
+    badge = RachaBadge(page, value=6)
+    section_header("Hola, Thiago", "Resumen de hoy", badge=badge.control)
+    ...
+    badge.set(6)            # setear sin animar (carga inicial)
+    badge.animate_to(7)     # setear + celebrar (cuando sube la racha)
+"""
+
+from __future__ import annotations
+
+import math
+import random
+import threading
+import time
+
+import flet as ft
+import theme as t
+
+
+# Poné en False si querés desactivar el confeti y dejar solo bounce + ignite.
+CONFETTI = True
+
+_AMBER      = t.NEUTRAL        # "#F59E0B" — llama prendida
+_AMBER_DK   = "#854F0B"        # número sobre el pill prendido
+_AMBER_TINT = "#FAEEDA"        # fondo del pill prendido
+_AMBER_BRD  = "#F6D9A6"        # borde del pill prendido
+_OFF        = t.TEXT_LIGHT     # "#9AA4B0" — llama/número apagados
+_OFF_BG     = t.CARD           # fondo del pill apagado
+_OFF_BRD    = t.DIVIDER        # borde del pill apagado
+
+
+class RachaBadge:
+    def __init__(self, page: ft.Page, value: int = 0) -> None:
+        self.page = page
+        self.value = int(value)
+
+        self._flame = ft.Icon(ft.icons.LOCAL_FIRE_DEPARTMENT, size=18)
+        self._count = ft.Text(str(self.value), size=15, weight=ft.FontWeight.W_600)
+
+        self._pill = ft.Container(
+            content=ft.Row([self._flame, self._count], spacing=4, tight=True),
+            padding=ft.padding.only(left=10, right=12, top=6, bottom=6),
+            border_radius=999,
+            scale=1.0,
+            animate_scale=ft.Animation(430, ft.AnimationCurve.BOUNCE_OUT),
+            tooltip="Racha de uso: días seguidos con al menos una sesión",
+        )
+
+        # Stack para tirar el confeti por encima del pill sin recortarlo.
+        self._stack = ft.Stack([self._pill], clip_behavior=ft.ClipBehavior.NONE)
+        self.control = self._stack
+
+        self._apply(active=self.value > 0)
+
+    # ── API pública ──────────────────────────────────────────────────────────
+    def set(self, value: int, animate: bool = False) -> None:
+        value = int(value)
+        self.value = value
+        self._count.value = str(value)
+        if animate and value > 0:
+            self.celebrate()
+        else:
+            self._apply(active=value > 0)
+            self._safe_update()
+
+    def animate_to(self, value: int) -> None:
+        self.set(value, animate=True)
+
+    def celebrate(self) -> None:
+        def run():
+            try:
+                self._apply(active=True)
+                self._pill.scale = 1.0
+                self._safe_update()
+                time.sleep(0.02)
+                self._pill.scale = 1.4
+                self._safe_update()
+                self._confetti()
+                time.sleep(0.42)
+                self._pill.scale = 1.0
+                self._safe_update()
+            except Exception:
+                pass
+        threading.Thread(target=run, daemon=True).start()
+
+    # ── Interno ──────────────────────────────────────────────────────────────
+    def _apply(self, active: bool) -> None:
+        self._flame.color = _AMBER if active else _OFF
+        self._count.color = _AMBER_DK if active else _OFF
+        self._pill.bgcolor = _AMBER_TINT if active else _OFF_BG
+        self._pill.border = ft.border.all(0.5, _AMBER_BRD if active else _OFF_BRD)
+
+    def _confetti(self) -> None:
+        if not CONFETTI:
+            return
+        try:
+            cx, cy = 24, 14  # aprox. centro del pill dentro del stack
+            cols = ["#03A097", t.NAVY, _AMBER, "#EF9F27", "#5DCAA5"]
+            parts: list[ft.Container] = []
+            for i in range(12):
+                p = ft.Container(
+                    width=6, height=6, bgcolor=cols[i % len(cols)], border_radius=2,
+                    left=cx, top=cy, opacity=1.0,
+                    animate_position=ft.Animation(820, ft.AnimationCurve.DECELERATE),
+                    animate_opacity=ft.Animation(820, ft.AnimationCurve.EASE_OUT),
+                )
+                parts.append(p)
+            self._stack.controls.extend(parts)
+            self._safe_update()
+
+            def fly():
+                time.sleep(0.02)
+                for p in parts:
+                    ang = random.uniform(0, 2 * math.pi)
+                    dist = random.uniform(26, 58)
+                    p.left = cx + math.cos(ang) * dist
+                    p.top = cy + math.sin(ang) * dist - 12  # sesgo hacia arriba
+                    p.opacity = 0.0
+                self._safe_update()
+                time.sleep(1.0)
+                for p in parts:
+                    if p in self._stack.controls:
+                        self._stack.controls.remove(p)
+                self._safe_update()
+
+            threading.Thread(target=fly, daemon=True).start()
+        except Exception:
+            pass
+
+    def _safe_update(self) -> None:
+        try:
+            self.page.update()
+        except Exception:
+            pass
